# Caddy runs as an internal HTTP router on localhost:8080. Public TLS is
# terminated by the host nginx vhost for $DOMAIN, which proxies to Caddy.
#
# Routing:
#   /api/*          →  Rust backend
#   /ws             →  Rust backend (WebSocket upgrade passes through natively)
#   /health,/ready  →  Rust backend readiness probes
#   /               →  SvelteKit SSR client

{
    email {$ACME_EMAIL}
}

http://{$DOMAIN} {
    encode zstd gzip

    @api path /api/* /ws /health /ready
    handle @api {
        reverse_proxy server:3001 {
            # Forward original headers so the backend sees the real client IP
            # for login/register throttling + audit logging.
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }

    handle {
        reverse_proxy client:3000
    }

    header {
        # HSTS — 1 year, includeSubDomains, preload-eligible.
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Permissions-Policy "geolocation=(), microphone=(self), camera=()"
        -Server
    }

    # Cap upload size on the public surface — must match the server's
    # DefaultBodyLimit so requests aren't accepted by Caddy and then 413'd
    # downstream. 1 MB is plenty for JSON payloads.
    request_body {
        max_size 1MB
    }
}
